<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup / device-transfer rules (Android 12+). FridgeOS provides its own
  encrypted backup (docs/09-security-design.md §6) and must not let the OS copy
  application data to the cloud or another device in cleartext. All data is
  excluded from both cloud backup and device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="external" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="external" path="."/>
    </device-transfer>
</data-extraction-rules>
